# Supabase (required)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key

# Recommended for server-side API routes (bypasses RLS; keep secret)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: stable UUID for demo user (defaults to built-in demo id)
# DEMO_USER_ID=00000000-0000-4000-8000-000000000001

# Exa — cheaper alternatives search (optional; heuristics used if missing)
EXA_API_KEY=
